# Copy this file to .env and fill in your values
# Never commit .env to git

# Required: Anthropic API key for LLM analysis
ANTHROPIC_API_KEY=sk-ant-...

# Optional: where to store data (default: ./data)
DATA_DIR=data

# Optional: Slack webhook for n8n alerts
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Optional: default semantic search query for n8n manual trigger
SEARCH_QUERY=AI market trends
